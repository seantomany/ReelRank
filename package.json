{
  "name": "reelrank",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev:api": "turbo run dev --filter=@reelrank/api",
    "dev:mobile": "turbo run dev --filter=@reelrank/mobile",
    "dev:web": "turbo run dev --filter=@reelrank/web",
    "test": "turbo run test",
    "lint": "turbo run lint",
    "clean": "turbo run clean"
  },
  "devDependencies": {
    "eas-cli": "^18.4.0",
    "turbo": "^2.3.0"
  },
  "packageManager": "pnpm@9.15.4",
  "engines": {
    "node": ">=20.0.0"
  },
  "pnpm": {
    "peerDependencyRules": {
      "allowedVersions": {
        "@react-native-async-storage/async-storage": ">=1.18.1",
        "react": ">=18.0.0",
        "react-dom": ">=18.0.0"
      }
    }
  }
}
