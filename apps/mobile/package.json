{
  "name": "@reelrank/mobile",
  "version": "0.1.0",
  "private": true,
  "main": "index.js",
  "scripts": {
    "start": "NODE_OPTIONS='--no-experimental-strip-types' expo start",
    "dev": "NODE_OPTIONS='--no-experimental-strip-types' expo start",
    "android": "NODE_OPTIONS='--no-experimental-strip-types' expo start --android",
    "ios": "NODE_OPTIONS='--no-experimental-strip-types' expo start --ios",
    "build": "echo 'Mobile build handled by EAS'",
    "test": "jest --passWithNoTests"
  },
  "dependencies": {
    "@babel/runtime": "^7.28.6",
    "@expo/vector-icons": "^14.0.0",
    "@react-native-async-storage/async-storage": "1.23.1",
    "@react-navigation/bottom-tabs": "^7.2.0",
    "@react-navigation/native": "^7.0.0",
    "@react-navigation/native-stack": "^7.2.0",
    "@reelrank/shared": "workspace:*",
    "ably": "^2.4.0",
    "expo": "~52.0.0",
    "expo-constants": "~17.0.0",
    "expo-haptics": "~14.0.0",
    "expo-linear-gradient": "~14.0.0",
    "expo-status-bar": "~2.0.0",
    "firebase": "^11.2.0",
    "hoist-non-react-statics": "^3.3.2",
    "invariant": "^2.2.4",
    "react": "18.3.1",
    "react-native": "0.76.6",
    "react-native-gesture-handler": "~2.20.0",
    "react-native-paper": "^5.12.0",
    "react-native-reanimated": "~3.16.0",
    "react-native-safe-area-context": "4.12.0",
    "react-native-screens": "~4.4.0",
    "react-native-svg": "15.8.0",
    "react-native-url-polyfill": "^3.0.0"
  },
  "devDependencies": {
    "@babel/core": "^7.25.0",
    "@testing-library/react-native": "^12.9.0",
    "@testing-library/jest-native": "^5.4.0",
    "@types/react": "~18.3.0",
    "dotenv": "^17.3.1",
    "jest": "^29.7.0",
    "jest-expo": "~52.0.0",
    "react-test-renderer": "18.3.1",
    "typescript": "^5.7.0"
  },
  "jest": {
    "preset": "jest-expo",
    "transformIgnorePatterns": [
      "node_modules/(?!((jest-)?react-native|@react-native(-community)?)|expo(nent)?|@expo(nent)?/.*|@expo-google-fonts/.*|react-navigation|@react-navigation/.*|@sentry/react-native|native-base|react-native-svg|@reelrank/shared)"
    ],
    "setupFilesAfterSetup": ["@testing-library/jest-native/extend-expect"],
    "moduleNameMapper": {
      "^@reelrank/shared$": "<rootDir>/../../packages/shared/src/index.ts"
    }
  }
}